datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

enum Role {
  ADMIN
  SELLER
  DEV
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum InstallmentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

enum TransactionStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum SaleStatus {
  ACTIVE
  CANCELLED
}

enum TradeInStatus {
  AGUARDANDO_AVALIACAO
  DISPONIVEL
  EM_REPARO
  AGUARDANDO_PECAS
  EM_MANUTENCAO
  EM_TESTES
  RESERVADO
  VENDIDO
  SUCATA
  DEVOLVIDO
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(SELLER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
}

model Customer {
  id           String        @id @default(uuid())
  name         String
  cpf          String        @unique
  rg           String?
  birthDate    DateTime?
  phone        String
  whatsApp     String?
  email        String?
  address         String?       // Logradouro (rua, av., etc.)
  addressNumber   String?       // Número
  neighborhood    String?       // Bairro
  city            String?       // Cidade
  state           String?       // Estado (UF)
  cep             String?       // CEP (apenas dígitos, 8 chars)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sales           Sale[]
  installments    Installment[]
}

model Product {
  id                 String        @id @default(uuid())
  brand              String
  model              String
  color              String
  storage            String
  imei               String?       // Opcional para acessórios, recomendado para aparelhos
  serialNumber       String?
  purchasePrice      Float
  sellingPrice       Float
  profit             Float
  quantity           Int           @default(1)
  warranty           String?       // Ex: "1 ano", "90 dias"
  imageUrl           String?       // URL ou base64 da foto
  status             ProductStatus @default(AVAILABLE)
  condition          String?       // Ex: "Novo", "Seminovo"
  hasAppleWarranty   Boolean?      // Se ainda possui garantia Apple
  appleWarrantyUntil DateTime?     // Prazo da garantia Apple
  isTradeIn          Boolean       @default(false)  // Identifica aparelhos originados de trade-in
  tradeInDeviceId    String?                        // Referência ao trade-in de origem
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  saleItems          SaleItem[]
}

model Sale {
  id                String                 @id @default(uuid())
  saleNumber        Int                    @unique @default(autoincrement())
  customer          Customer               @relation(fields: [customerId], references: [id])
  customerId        String
  totalAmount       Float
  discountAmount    Float                  @default(0)
  netAmount         Float
  downPayment       Float                  @default(0)
  paymentMethod     String                 // PIX, DINHEIRO, CARTAO, BOLETO, PARCELADO_LOJA
  installmentCount  Int                    @default(1)
  surchargeAmount   Float                  @default(0) // Acréscimo (juros/taxa) sobre o valor parcelado
  tradeInAmount     Float                  @default(0) // Valor do aparelho recebido em trade-in
  signedContractUrl String?                // Link do PDF do contrato assinado carregado pelo usuário
  status            SaleStatus             @default(ACTIVE)
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  items             SaleItem[]
  installments      Installment[]
  transactions      FinancialTransaction[]
  tradeInDevice     TradeInDevice?
}

model SaleItem {
  id         String   @id @default(uuid())
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId     String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
}

model Installment {
  id                String                 @id @default(uuid())
  sale              Sale                   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId            String
  customer          Customer               @relation(fields: [customerId], references: [id])
  customerId        String
  installmentNumber Int
  amount            Float
  dueDate           DateTime
  status            InstallmentStatus      @default(PENDING)
  paidAmount        Float                  @default(0)
  paymentDate       DateTime?
  remainingAmount   Float
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  transactions      FinancialTransaction[]
}

model FinancialTransaction {
  id            String            @id @default(uuid())
  type          TransactionType
  category      String            // Ex: "Venda", "Recebimento de Parcela", "Compra de Mercadoria", "Despesa Administrativa"
  amount        Float
  date          DateTime
  description   String?
  status        TransactionStatus @default(PAID)
  saleId        String?
  sale          Sale?             @relation(fields: [saleId], references: [id])
  installmentId String?
  installment   Installment?      @relation(fields: [installmentId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String   // Ex: "LOGIN", "CADASTRAR_VENDA", "EXCLUIR_PRODUTO"
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}

model CompanySetting {
  id            String   @id @default(uuid())
  tipo          String?  @default("PJ")  // "PF" ou "PJ"
  name          String
  tradeName     String?  // Nome Fantasia
  cnpj          String   // CNPJ (PJ) ou CPF (PF)
  rg            String?  // RG - somente para PF
  ie            String?  // Inscrição Estadual - somente para PJ
  address       String
  neighborhood  String?  // Bairro
  city          String?
  state         String?
  cep           String?
  phone         String
  whatsApp      String?
  email         String
  logoUrl       String?  // URL ou base64 do logotipo
  contractTerms String?  // Cláusulas contratuais em formato de texto
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// TRADE-IN
// ─────────────────────────────────────────────────────────────────────────────

model TradeInDevice {
  id              String               @id @default(uuid())
  brand           String
  model           String
  color           String
  storage         String
  imei1           String?
  imei2           String?
  serialNumber    String?
  carrier         String?
  evaluationPrice Float
  condition       String               // Novo, Excelente, Bom, Regular, Ruim
  notes           String?
  photos          String?              // JSON array de base64 strings
  checklist       String?              // JSON { screenOk: true, touchOk: true, ... }
  status          TradeInStatus        @default(AGUARDANDO_AVALIACAO)

  saleId          String               @unique
  sale            Sale                 @relation(fields: [saleId], references: [id])
  customerId      String
  evaluatedById   String?

  productId       String?              // ID do Product gerado no estoque

  repairs         TradeInRepair[]
  statusHistory   TradeInStatusHistory[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model TradeInRepair {
  id         String        @id @default(uuid())
  device     TradeInDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId   String
  defect     String
  service    String
  parts      String?
  cost       Float
  startDate  DateTime
  endDate    DateTime?
  technician String
  createdAt  DateTime      @default(now())
}

model TradeInStatusHistory {
  id        String        @id @default(uuid())
  device    TradeInDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId  String
  status    TradeInStatus
  note      String?
  userId    String?
  createdAt DateTime      @default(now())
}
